  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-gemini-auth@latest"
  ],
  "skills": {
    "paths": [
      "~/.config/opencode/skills"
    ]
  },
  "permission": {
    "skill": {
      "caveman": "allow",
      "*": "allow"
    }
